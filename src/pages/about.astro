---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="A short introduction: who I am and what this site is for."
  canonicalPath="/about/"
>
  <article class="about-page site-shell" data-reveal>
    <h1>About</h1>
    <div class="about-page-prose post-prose">
      <p>
        Hi — I'm <strong>Mengqing Chen</strong>. I grew up in southwest China, was born in &rsquo;97, and
        work as a software engineer. I used to want to be a writer; code won out day-to-day, but I still
        like clear sentences.
      </p>
      <p>
        Think of this site as a small <strong>digital coffee shop</strong>: mostly notes on building
        software, tools, and things I learned the slow way — with room for the occasional personal
        aside.
      </p>
      <p>
        <a class="text-link" href="https://github.com/ElmTran">GitHub</a> · say hello via the footer.
      </p>
    </div>
  </article>
</BaseLayout>
