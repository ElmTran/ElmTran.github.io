---
import { getCollection } from "astro:content";
import PostShell from "../../../components/PostShell.astro";
import { getLegacySlug, getPostUrl, sortPosts } from "../../../lib/posts";

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection("blog"));

  return posts.map((post) => ({
    params: { legacy: getLegacySlug(post) },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
---

<PostShell post={post} posts={posts} canonicalPath={getPostUrl(post)} />
