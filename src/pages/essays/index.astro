---
import { getCollection } from "astro:content";
import Main from "../../layouts/BaseLayout.astro";
import EssayList from "../../components/EssayList.astro";
import { sortPosts } from "../../lib/posts";

const posts = sortPosts(await getCollection("blog"));
---

<Main
  title="Essays"
  description="A chronological index of essays, notes, and long-form writing."
  canonicalPath="/essays/"
>
  <section class="page-intro site-shell page-intro--compact" data-reveal>
    <h1>Essays</h1>
  </section>

  <section class="site-shell">
    <EssayList posts={posts} />
  </section>

  <script is:inline>
    (function () {
      function isEssaysIndexPath() {
        const normalized = (location.pathname.replace(/\/$/, "") || "/").toLowerCase();
        return normalized === "/essays";
      }

      if (!isEssaysIndexPath()) {
        return;
      }

      const form = document.querySelector("form.site-nav-search");
      const searchEl = document.getElementById("site-essay-search");

      function rows() {
        return document.querySelectorAll("[data-essay-row]");
      }

      function sections() {
        return document.querySelectorAll("[data-essay-year]");
      }

      function readUrl() {
        const p = new URLSearchParams(window.location.search);
        if (searchEl instanceof HTMLInputElement) {
          searchEl.value = p.get("q") || "";
        }
      }

      function syncUrl(qRaw, tag, category) {
        const p = new URLSearchParams();
        if (qRaw) p.set("q", qRaw);
        if (tag) p.set("tag", tag);
        if (category) p.set("category", category);
        const qs = p.toString();
        const path = window.location.pathname;
        history.replaceState(null, "", qs ? `${path}?${qs}` : path);
      }

      function parseRow(row) {
        return {
          el: row,
          tags: JSON.parse(row.dataset.tags || "[]"),
          categories: JSON.parse(row.dataset.categories || "[]"),
          blob: (row.dataset.search || "").toLowerCase(),
        };
      }

      function pruneFilters(qRaw, tag, category, rowData) {
        const q = qRaw.toLowerCase();
        const matchSearch = function (r) {
          return !q || r.blob.includes(q);
        };
        const base = rowData.filter(matchSearch);
        var nextTag = tag;
        var nextCat = category;

        if (nextTag && !base.some(function (r) { return r.tags.includes(nextTag); })) {
          nextTag = "";
        }
        if (nextCat && !base.some(function (r) { return r.categories.includes(nextCat); })) {
          nextCat = "";
        }

        if (nextTag) {
          var withTag = base.filter(function (r) {
            return r.tags.includes(nextTag);
          });
          var catSet = new Set();
          for (var i = 0; i < withTag.length; i++) {
            var r = withTag[i];
            for (var j = 0; j < r.categories.length; j++) {
              catSet.add(r.categories[j]);
            }
          }
          if (nextCat && !catSet.has(nextCat)) {
            nextCat = "";
          }
        }

        if (nextCat) {
          var withCat = base.filter(function (r) {
            return r.categories.includes(nextCat);
          });
          var tagSet = new Set();
          for (var k = 0; k < withCat.length; k++) {
            var r2 = withCat[k];
            for (var m = 0; m < r2.tags.length; m++) {
              tagSet.add(r2.tags[m]);
            }
          }
          if (nextTag && !tagSet.has(nextTag)) {
            nextTag = "";
          }
        }

        return { tag: nextTag, category: nextCat };
      }

      function apply() {
        var p0 = new URLSearchParams(window.location.search);
        var tag = p0.get("tag") || "";
        var category = p0.get("category") || "";
        var qRaw = searchEl instanceof HTMLInputElement ? searchEl.value.trim() : "";

        var rowData = [];
        for (var i = 0; i < rows().length; i++) {
          var row = rows()[i];
          if (row instanceof HTMLElement) {
            rowData.push(parseRow(row));
          }
        }

        var pruned = pruneFilters(qRaw, tag, category, rowData);
        if (pruned.tag !== tag || pruned.category !== category) {
          tag = pruned.tag;
          category = pruned.category;
        }

        syncUrl(qRaw, tag, category);

        var q = qRaw.toLowerCase();
        for (var j = 0; j < rowData.length; j++) {
          var rd = rowData[j];
          var ok =
            (!q || rd.blob.includes(q)) &&
            (!tag || rd.tags.includes(tag)) &&
            (!category || rd.categories.includes(category));
          rd.el.hidden = !ok;
        }

        for (var s = 0; s < sections().length; s++) {
          var sec = sections()[s];
          if (!(sec instanceof HTMLElement)) {
            continue;
          }
          var any = sec.querySelector("[data-essay-row]:not([hidden])");
          sec.hidden = !any;
        }

      }

      readUrl();
      apply();

      window.addEventListener("popstate", function () {
        readUrl();
        apply();
      });

      searchEl?.addEventListener("input", apply);

      form?.addEventListener("submit", function (e) {
        e.preventDefault();
        apply();
      });

      document.addEventListener("keydown", function (e) {
        if (e.key !== "/" || e.ctrlKey || e.metaKey || e.altKey) {
          return;
        }
        var target = e.target;
        if (
          target instanceof HTMLInputElement ||
          target instanceof HTMLTextAreaElement ||
          (target instanceof HTMLElement && target.isContentEditable)
        ) {
          return;
        }
        e.preventDefault();
        searchEl?.focus();
        if (searchEl instanceof HTMLInputElement) {
          searchEl.select();
        }
      });
    })();
  </script>
</Main>
