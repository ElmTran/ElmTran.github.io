---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectTaxonomy, getPostUrl, sortPosts } from "../../lib/posts";

const posts = sortPosts(await getCollection("blog"));
const tags = collectTaxonomy(posts, "tags");
---

<BaseLayout title="Tags" description="A restrained index of recurring topics." canonicalPath="/essays/tags/">
  <section class="taxonomy-section site-shell">
    <div class="page-intro page-intro--compact">
      <h1>Tags</h1>
      <p class="page-intro-single">Grouped by topic; each links back into the archive.</p>
    </div>

    <div class="taxonomy-grid">
      {
        tags.map((tag) => {
          const related = posts.filter((post) => post.data.tags.includes(tag.name)).slice(0, 2);

          return (
            <article class="taxonomy-card">
              <p class="eyebrow">{tag.count} essay{tag.count > 1 ? "s" : ""}</p>
              <h3>{tag.name}</h3>
              <p>{related.map((post) => post.data.title).join(" / ")}</p>
              {related[0] && (
                <a class="text-link" href={getPostUrl(related[0])}>
                  Open latest
                </a>
              )}
            </article>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
